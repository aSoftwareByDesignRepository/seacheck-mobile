{
  "name": "seacheck-mobile",
  "version": "0.1.2",
  "main": "index.ts",
  "license": "AGPL-3.0-or-later",
  "engines": {
    "node": "^20.19.4 || ^22.13.0 || ^24.3.0 || >=25.0.0"
  },
  "scripts": {
    "dev": "bash scripts/dev-emulator.sh",
    "start": "expo start --port 8092",
    "android": "bash scripts/run-android.sh",
    "android:clean": "bash scripts/android-clean.sh",
    "android:rebuild": "bash scripts/android-clean.sh && npm run android",
    "android:release": "SEACHECK_APP_VARIANT=production NODE_ENV=production bash scripts/ensure-android-local-properties.sh && cd android && SEACHECK_APP_VARIANT=production NODE_ENV=production ./gradlew assembleRelease",
    "android:bundle": "SEACHECK_APP_VARIANT=production NODE_ENV=production bash scripts/ensure-android-local-properties.sh && cd android && SEACHECK_APP_VARIANT=production NODE_ENV=production ./gradlew bundleRelease",
    "android:dev": "CI=1 expo run:android --port 8092",
    "release:apk": "bash scripts/release-apk.sh",
    "ios": "expo run:ios --port 8092",
    "typecheck": "tsc --noEmit",
    "a11y:contrast": "node scripts/contrast-check.mjs",
    "a11y:touch": "node scripts/a11y-touch-target-audit.mjs",
    "i18n:parity": "node scripts/i18n-parity.mjs",
    "test": "jest",
    "test:downloads": "jest --testPathPattern='downloadTiming|downloadStallWatchdog|nativePackProgress|nativePackStatus|offlinePackStore.startDownload|offlinePackStore.hydrate|resolveOfflineEngineCamera|offlineMapEngineHost|downloadNetwork|downloadCoordinator|reportDownloadFailure'",
    "reload": "bash scripts/reload-js.sh",
    "logs:downloads": "bash scripts/watch-download-logs.sh",
    "preflight": "bash scripts/preflight.sh",
    "fdroid:preflight": "bash scripts/fdroid-preflight.sh",
    "play:preflight": "bash scripts/play-preflight.sh",
    "sync:regions": "node scripts/sync-planning-regions.mjs",
    "icons": "node scripts/generate-app-icons.mjs",
    "postinstall": "bash scripts/patch-gradle-foojay.sh && bash scripts/patch-expo-node.sh && bash scripts/patch-expo-kotlin.sh && bash scripts/patch-node-gradle.sh && bash scripts/patch-expo-constants-env.sh"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@maplibre/maplibre-react-native": "11.3.6",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "9.1.0",
    "@react-native-community/netinfo": "12.0.1",
    "@react-navigation/bottom-tabs": "^7.16.2",
    "@react-navigation/native": "^7.2.5",
    "@react-navigation/native-stack": "^7.16.0",
    "@turf/helpers": "^7.3.5",
    "@turf/rhumb-bearing": "^7.3.5",
    "@turf/rhumb-destination": "^7.3.5",
    "@turf/rhumb-distance": "^7.3.5",
    "@turf/turf": "^7.3.5",
    "babel-preset-expo": "~56.0.0",
    "expo": "~56.0.16",
    "expo-application": "~56.0.3",
    "expo-audio": "~56.0.12",
    "expo-battery": "~56.0.4",
    "expo-clipboard": "~56.0.4",
    "expo-device": "~56.0.4",
    "expo-file-system": "~56.0.8",
    "expo-haptics": "~56.0.3",
    "expo-intent-launcher": "~56.0.4",
    "expo-keep-awake": "~56.0.3",
    "expo-localization": "~56.0.6",
    "expo-location": "~56.0.21",
    "expo-notifications": "~56.0.21",
    "expo-sharing": "~56.0.22",
    "expo-sqlite": "~56.0.5",
    "expo-status-bar": "~56.0.4",
    "expo-task-manager": "~56.0.22",
    "geomag": "^1.0.0",
    "i18n-js": "^4.5.3",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@react-native/jest-preset": "0.85.3",
    "@resvg/resvg-js": "^2.6.2",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "expo-dev-client": "~56.0.23",
    "jest": "^29.7.0",
    "jest-expo": "~56.0.4",
    "react-test-renderer": "19.2.3",
    "typescript": "~6.0.3"
  }
}
