# Release signing — not committed. For SBD internal builds, copy to:
#   mobile/seacheck-private/keystore.properties
# Paths below are relative to mobile/seacheck/android/ (Gradle rootProject).

storeFile=../../seacheck-private/key/key.jks
storePassword=your-store-password
keyAlias=your-key-alias
keyPassword=your-key-password

# Create key (first Play release for de.softwarebydesign.seacheck):
#   keytool -genkeypair -v -storetype PKCS12 \\
#     -keystore mobile/seacheck-private/key/key.jks \\
#     -alias seacheck -keyalg RSA -keysize 2048 -validity 10000
